<configuration scan="true">

    <!-- Common encoder pattern -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- === Appenders per module === -->

    <appender name="AUTH" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/auth.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/auth-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="ADMIN" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/admin.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/admin-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="CERTIFICATE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/certificate.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/certificate-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="CONFIG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/config.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/config-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="JOB" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/job.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/job-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="NOTIFICATION" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/notification.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/notification-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="PAYMENT" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/payment.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/payment-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="PROJECT" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/project.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/project-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="REVIEW" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/review.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/review-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="SUBMISSION" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/submission.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/submission-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="USER" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/user.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/user-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- === General fallback appender === -->
    <appender name="COMMON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/application-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    

    <!-- === Loggers per package/module === -->
    <logger name="com.certplatform.auth.controller" level="INFO">
        <appender-ref ref="AUTH"/>
    </logger>

    <logger name="com.certplatform.admin" level="INFO">
        <appender-ref ref="ADMIN"/>
    </logger>

    <logger name="com.certplatform.certificate" level="INFO">
        <appender-ref ref="CERTIFICATE"/>
    </logger>

    <logger name="com.certplatform.config" level="INFO" additivity="false">
        <appender-ref ref="CONFIG"/>
    </logger>

    <logger name="com.certplatform.job" level="INFO" additivity="false">
        <appender-ref ref="JOB"/>
    </logger>

    <logger name="com.certplatform.notification" level="INFO" additivity="false">
        <appender-ref ref="NOTIFICATION"/>
    </logger>

    <logger name="com.certplatform.payment" level="INFO" additivity="false">
        <appender-ref ref="PAYMENT"/>
    </logger>

    <logger name="com.certplatform.project" level="INFO" additivity="false">
        <appender-ref ref="PROJECT"/>
    </logger>

    <logger name="com.certplatform.review" level="INFO" additivity="false">
        <appender-ref ref="REVIEW"/>
    </logger>

    <logger name="com.certplatform.submission" level="INFO" additivity="false">
        <appender-ref ref="SUBMISSION"/>
    </logger>

    <logger name="com.certplatform.user" level="INFO">
        <appender-ref ref="USER"/>
    </logger>

    <logger name="com.certplatform.common" level="INFO" additivity="false">
        <appender-ref ref="COMMON"/> <!-- or whichever module you want to capture common logs -->
    </logger>

    <!-- Root logger: fallback for everything else -->
    <root level="INFO">
        <appender-ref ref="AUTH"/>
    </root>


</configuration>